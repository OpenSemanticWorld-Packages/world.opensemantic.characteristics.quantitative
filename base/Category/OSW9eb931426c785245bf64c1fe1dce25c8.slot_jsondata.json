    "label": [
        {
            "text": "Volumetric Heat Capacity",
            "lang": "en"
        }
    ],
    "description": [
        {
            "text": "$\\textit{Volumetric Heat Capacity (VHC)}$, also termed $\\textit{volume-specific heat capacity}$, describes the ability of a given volume of a substance to store internal energy while undergoing a given temperature change, but without undergoing a phase transition. It is different from specific heat capacity in that the VHC is a $\\textit{per unit volume}$ measure of the relationship between thermal energy and temperature of a material, while the specific heat is a $\\textit{per unit mass}$ measure (or occasionally per molar quantity of the material).",
            "lang": "en"
        }
    ],
